<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.tcltech.urc-rose-bridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/urc-rose-bridge/urc-rose-bridge</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/usr/local/urc-rose-bridge</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/usr/local/var/log/urc-rose-bridge.out.log</string>
  <key>StandardErrorPath</key>
  <string>/usr/local/var/log/urc-rose-bridge.err.log</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/usr/bin:/bin</string>
  </dict>
</dict>
</plist>